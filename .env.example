# DigitLink推广Agent环境变量配置
# 复制这份文件为.env并填入你的值

# ===================
# API Keys（必填）
# ===================

# OpenRouter API Key（用于多模型问答）
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===================
# DigitLink账号（必填）
# ===================

# DigitLink账号邮箱
DIGITLINK_EMAIL=opendigitlink@gmail.com

# DigitLink账号密码
DIGITLINK_PASSWORD=your_password_here

# ===================
# Telegram通知（可选）
# ===================

# Telegram Bot Token（用于接收任务通知）
TELEGRAM_BOT_TOKEN=

# ===================
# 社交平台账号（可选）
# ===================

# TikTok账号
TIKTOK_USERNAME=
TIKTOK_PASSWORD=

# Instagram账号
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Facebook账号
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# ===================
# AIVideoMaker（可选）
# ===================

# AIVideoMaker API Key
AIVIDEO_API_KEY=

# ===================
# Nanobrowser（可选）
# ===================

# Nanobrowser API Key（用于竞品监控）
NANOBROWSER_API_KEY=

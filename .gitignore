# Dependencies
node_modules/

# Environment
.env
.env.local

# State files (generated at runtime)
state/**/*.json
!state/template.json

# Evidence (generated at runtime)
evidence/**/*.png
evidence/**/*.html
evidence/**/*.json
!evidence/.gitkeep

# Data (generated at runtime)
data/**/*.json
!data/.gitkeep

# Logs (generated at runtime)
logs/*.log

# Reports (generated at runtime)
reports/**/*.md
!reports/.gitkeep

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Git
.git/objects/
